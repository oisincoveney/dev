{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.agents/hooks/bin:$PATH\" OISIN_DEV_HOOK_DIR=\".agents/hooks\" .agents/hooks/run-quiet.sh .agents/hooks/context-bootstrap.sh .agents/hooks/baseline-pin.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.agents/hooks/bin:$PATH\" OISIN_DEV_HOOK_DIR=\".agents/hooks\" .agents/hooks/run-quiet.sh .agents/hooks/context-injector.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.agents/hooks/bin:$PATH\" OISIN_DEV_HOOK_DIR=\".agents/hooks\" OISIN_DEV_BACKLOG=1 OISIN_DEV_TYPESCRIPT=1 .agents/hooks/pre-tool-dispatch.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.agents/hooks/bin:$PATH\" OISIN_DEV_HOOK_DIR=\".agents/hooks\" .agents/hooks/run-quiet.sh .agents/hooks/post-edit-async.sh .agents/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.agents/hooks/bin:$PATH\" OISIN_DEV_HOOK_DIR=\".agents/hooks\" .agents/hooks/run-quiet.sh .agents/hooks/worktree-stop-guard.sh .agents/hooks/post-edit-await.sh .agents/hooks/pre-stop-verification.sh .agents/hooks/verifier-skill-guard.sh .agents/hooks/baseline-compare.sh .agents/hooks/citation-check.sh .agents/hooks/ai-antipattern-guard.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.agents/hooks/bin:$PATH\" OISIN_DEV_HOOK_DIR=\".agents/hooks\" .agents/hooks/run-quiet.sh .agents/hooks/pre-compact-prime.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cd \"$(git rev-parse --show-toplevel)\" && .agents/hooks/statusline.sh"
  },
  "permissions": {
    "mode": "default",
    "rules": [
      {
        "tool": "Bash",
        "decision": "deny",
        "if": "Bash(rm -rf|git reset --hard)",
        "reason": "Destructive commands require explicit user approval"
      },
      {
        "tool": "Read",
        "decision": "allow",
        "reason": "Read-only file access"
      },
      {
        "tool": "Glob",
        "decision": "allow",
        "reason": "Read-only search"
      },
      {
        "tool": "Grep",
        "decision": "allow",
        "reason": "Read-only search"
      },
      {
        "tool": "Bash",
        "decision": "allow",
        "if": "Bash(tsc --noEmit|echo \"no lint configured\"|bun test|git status|git diff|git log|git-spice *|backlog *)",
        "reason": "Safe verification and task tracking"
      },
      {
        "tool": "Bash",
        "decision": "ask",
        "if": "Bash(git commit*|git push*)",
        "reason": "Git operations require review"
      },
      {
        "tool": "Edit",
        "decision": "ask",
        "reason": "Code changes require approval"
      },
      {
        "tool": "Write",
        "decision": "ask",
        "reason": "File creation requires approval"
      }
    ]
  }
}
