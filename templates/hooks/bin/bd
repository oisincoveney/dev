#!/usr/bin/env bash
# bd shim — installed by @oisincoveney/dev. Resolves the bd binary in
# priority order so hooks and the agent get a consistent per-repo bd
# regardless of how the user installed it (mise, aqua, npm, manual).
#
# Resolution order:
#   1. .beads/bin/bd          (project-vendored, repo-local)
#   2. node_modules/.bin/bd   (npm/bun bundled)
#   3. mise exec -- bd        (mise.toml-managed, e.g. aqua:steveyegge/beads)
#   4. PATH bd                (global install — fallback)
#
# Removing this shim or its parent dir from PATH falls back to whatever
# `bd` resolves to globally. Safe to delete.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

if [[ -x "$REPO_ROOT/.beads/bin/bd" ]]; then
  exec "$REPO_ROOT/.beads/bin/bd" "$@"
fi

if [[ -x "$REPO_ROOT/node_modules/.bin/bd" ]]; then
  exec "$REPO_ROOT/node_modules/.bin/bd" "$@"
fi

if [[ -f "$REPO_ROOT/mise.toml" ]] && command -v mise >/dev/null 2>&1; then
  if mise which bd >/dev/null 2>&1; then
    exec mise exec -- bd "$@"
  fi
fi

# Fallback: PATH lookup, but skip THIS shim's directory to avoid recursion.
SHIM_DIR="$(cd "$(dirname "$0")" && pwd)"
SAFE_PATH=""
IFS=:
for dir in $PATH; do
  if [[ "$dir" != "$SHIM_DIR" ]]; then
    SAFE_PATH="${SAFE_PATH:+$SAFE_PATH:}$dir"
  fi
done
unset IFS

if BD_REAL="$(env PATH="$SAFE_PATH" command -v bd 2>/dev/null)"; then
  exec "$BD_REAL" "$@"
fi

echo "bd shim: no bd binary found. Install via mise (mise.toml uses aqua:steveyegge/beads) or curl https://raw.githubusercontent.com/steveyegge/beads/main/scripts/install.sh | bash" >&2
exit 127
