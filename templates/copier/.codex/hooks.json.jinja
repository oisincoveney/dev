{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/context-bootstrap.sh .codex/hooks/baseline-pin.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/{% if beads_enabled %}bd-context-inject.sh{% else %}context-injector.sh{% endif %}",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" {% if beads_enabled %}OISIN_DEV_BEADS=1 {% endif %}{% if has_typescript %}OISIN_DEV_TYPESCRIPT=1 {% endif %}.codex/hooks/pre-tool-dispatch.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/post-edit-async.sh .codex/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/worktree-stop-guard.sh{% if beads_enabled %} .codex/hooks/swarm-digest.sh{% endif %} .codex/hooks/post-edit-await.sh .codex/hooks/pre-stop-verification.sh .codex/hooks/verifier-skill-guard.sh .codex/hooks/baseline-compare.sh .codex/hooks/citation-check.sh .codex/hooks/ai-antipattern-guard.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/pre-compact-prime.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
