# lefthook.yml — generated by @oisincoveney/dev

commit-msg:
  commands:
    conventional-commits:
      run: |
        if ! head -1 {1} | grep -qE '^(feat|fix|chore|refactor|test|docs|style|perf|ci|build|revert)(\([a-z0-9-]+\))?!?: .+'; then
          echo "Commit message must follow Conventional Commits format."
          exit 1
        fi

pre-commit:
  parallel: true
  commands:
{% if "typecheck" in commands %}
    typecheck:
      run: mise run typecheck
{% endif %}
{% if "lint" in commands %}
    lint:
      run: mise run lint
{% endif %}

pre-push:
  commands:
{% if "test" in commands %}
    test:
      run: mise run test
{% endif %}
{% if "e2e" in commands %}
    e2e:
      run: mise run e2e
{% endif %}
    pr-size-check:
      run: .claude/hooks/pr-size-check.sh
    semgrep:
      run: |
        if command -v semgrep >/dev/null 2>&1; then
          semgrep --config p/security-audit --config p/owasp-top-ten --error
        fi
