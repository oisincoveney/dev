[tools]
{% if package_manager == "bun" -%}
bun = "1.3"
{% endif -%}
"pipx:copier" = "9.14.0"
"npm:@sentry/dotagents" = "latest"
"aqua:evilmartians/lefthook" = "latest"
{% if beads_enabled -%}
"aqua:steveyegge/beads" = "1.0.2"
{% endif %}

{% for name, command in commands.items() %}
[tasks.{{ name }}]
run = {{ command | tojson }}
{% endfor %}
{% set verify = [] -%}
{% for name in ["typecheck", "lint", "test"] -%}
{% if name in commands -%}
{% set _ = verify.append(name) -%}
{% endif -%}
{% endfor -%}
{% if verify %}
[tasks.verify]
depends = [{% for name in verify %}"{{ name }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{% endif -%}
