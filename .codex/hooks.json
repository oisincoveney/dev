{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/context-bootstrap.sh .codex/hooks/baseline-pin.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/context-injector.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" OISIN_DEV_TYPESCRIPT=1 .codex/hooks/pre-tool-dispatch.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/post-edit-check.sh .codex/hooks/ai-antipattern-guard.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/worktree-stop-guard.sh .codex/hooks/pre-stop-verification.sh .codex/hooks/verifier-skill-guard.sh .codex/hooks/baseline-compare.sh .codex/hooks/citation-check.sh .codex/hooks/ai-antipattern-guard.sh .codex/hooks/banned-words-guard.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/run-quiet.sh .codex/hooks/pre-compact-prime.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
