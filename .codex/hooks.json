{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/context-bootstrap.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/baseline-pin.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/context-injector.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/audit-log.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/docs-first.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/worktree-write-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/ts-style-guard.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/import-validator.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/destructive-command-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/block-coauthor.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/block-todowrite.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/post-edit-check.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/worktree-stop-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/pre-stop-verification.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/verifier-skill-guard.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/baseline-compare.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/citation-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/banned-words-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && PATH=\"$PWD/.codex/hooks/bin:$PATH\" .codex/hooks/pre-compact-prime.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
